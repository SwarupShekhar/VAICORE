FROM python:3.10-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    wget \
    git \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install label-studio-ml and SAM dependencies
RUN pip install --no-cache-dir \
    label-studio-ml \
    label-studio-sdk \
    torch torchvision --index-url https://download.pytorch.org/whl/cpu \
    mobile-sam \
    Pillow \
    numpy \
    opencv-python-headless

# Create model directory
RUN mkdir -p /data/models

# Download MobileSAM weights
RUN wget -q -O /data/models/mobile_sam.pt \
    https://github.com/ChaoningZhang/MobileSAM/raw/master/weights/mobile_sam.pt || \
    echo "Will download on first run"

# Copy the SAM backend script
COPY sam_backend.py /app/sam_backend.py

EXPOSE 9090

ENV SAM_CHOICE=MobileSAM
ENV MODEL_DIR=/data/models
ENV LOG_LEVEL=DEBUG
ENV WORKERS=1
ENV THREADS=4

CMD ["label-studio-ml", "start", "/app/sam_backend.py", "--host", "0.0.0.0", "--port", "9090"]
