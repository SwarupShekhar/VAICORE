FROM python:3.10-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    wget git libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# 1. Pin numpy<2 FIRST — torch 2.1.0 is not compatible with numpy 2.x
RUN pip install --no-cache-dir "numpy<2"

# 2. PyTorch CPU (needs its own index URL)
RUN pip install --no-cache-dir \
    torch==2.1.0 torchvision==0.16.0 \
    --index-url https://download.pytorch.org/whl/cpu

# 3. MobileSAM from GitHub source (no valid PyPI distribution)
RUN pip install --no-cache-dir \
    git+https://github.com/ChaoningZhang/MobileSAM.git

# 4. Label Studio ML + all required runtime deps
RUN pip install --no-cache-dir \
    label-studio-ml==1.0.9 \
    label-studio-sdk \
    redis \
    rq \
    Pillow \
    opencv-python-headless

RUN mkdir -p /data/models
COPY sam_backend.py /app/sam_backend.py

EXPOSE 9090

ENV SAM_CHOICE=MobileSAM
ENV MODEL_DIR=/data/models
ENV LOG_LEVEL=DEBUG
ENV WORKERS=1
ENV THREADS=4

CMD ["label-studio-ml", "start", "/app/sam_backend.py", "--host", "0.0.0.0", "--port", "9090"]
